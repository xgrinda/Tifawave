# Public production origin used for canonical URLs, sitemap.xml, robots.txt,
# and Open Graph metadata.
NEXT_PUBLIC_SITE_URL=https://tifawave.com

# Supabase
# Create a Supabase project, then copy these from Project Settings > API.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_STORAGE_BUCKET=tifawave-content

# Simple admin login for /admin/login.
# Use a strong password in production and set these in Vercel env vars.
ADMIN_EMAIL=admin@tifawave.com
ADMIN_PASSWORD=use-a-strong-password

# Production inbox that receives booking inquiry emails.
BOOKING_RECIPIENT_EMAIL=hello@tifawave.com

# Optional local JSONL fallback. Do not rely on filesystem writes on Vercel.
BOOKING_STORE_PATH=.data/booking-inquiries.jsonl

# Resend email delivery.
# Local: put this in `.env.local`.
# Vercel: Project Settings > Environment Variables.
# Create the API key in Resend after verifying your sending domain.
RESEND_API_KEY=
BOOKING_EMAIL_FROM="Tifawave Bookings <bookings@tifawave.com>"

# Optional future Nodemailer/SMTP swap.
# This implementation uses Resend, but these are the SMTP credentials you would
# add if you replace `src/lib/email-service.ts` with Nodemailer transport code.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="Tifawave Bookings <bookings@tifawave.com>"
